<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Mady Semijoias</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <img src="/public/img/logo.png" alt="Mady Semijoias">
      <div>
        <h1>Mady Semijoias</h1>
        <span>Controle profissional de estoque</span>
      </div>
    </div>

    <% if (user) { %>
      <nav>
        <% if (user.role === 'admin') { %>
          <a href="/admin">Produtos</a>
          <a href="/admin/clientes">Clientes</a>
          <a href="/admin/movimentacoes">Movimentações</a>
        <% } else { %>
          <a href="/cliente">Produtos</a>
          <a href="/cliente/carrinho">Carrinho</a>
          <a href="/cliente/minha-conta">Minha conta</a>
        <% } %>

        <form action="/logout" method="POST">
          <button class="logout">Sair</button>
        </form>
      </nav>
    <% } %>
  </header>

  <main class="container">
    <% if (success && success.length > 0) { %>
      <div class="alert success"><%= success[0] %></div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert error"><%= error[0] %></div>
    <% } %>

    <%- body %>
  </main>

  <script src="/public/js/app.js"></script>
</body>
</html>
